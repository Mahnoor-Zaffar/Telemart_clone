# Database
DATABASE_URL="postgresql://telemart:telemart@localhost:5432/telemart?schema=public"
MONGODB_URI="mongodb://localhost:27017/telemart"

# Redis
REDIS_URL="redis://localhost:6379"

# Meilisearch (Phase 2)
MEILISEARCH_HOST="http://localhost:7700"
