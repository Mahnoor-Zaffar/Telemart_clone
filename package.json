{
  "name": "telemart-clone",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "dotenv -e .env -- turbo dev",
    "predev": "node scripts/kill-dev-ports.mjs",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "dotenv -e .env -- npm run db:generate --workspace=@telemart/api",
    "db:push": "dotenv -e .env -- npm run db:push --workspace=@telemart/api",
    "db:migrate": "dotenv -e .env -- npm run db:migrate --workspace=@telemart/api",
    "db:seed": "dotenv -e .env -- npm run db:seed --workspace=@telemart/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "test:api": "npm run test:e2e --workspace=@telemart/api",
    "test:e2e": "playwright test",
    "screenshots": "playwright test e2e/screenshots.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2"
}
