{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@telemart/types$": "<rootDir>/../../../packages/types/src/index.ts",
    "^meilisearch$": "<rootDir>/mocks/meilisearch.mock.ts"
  }
}
